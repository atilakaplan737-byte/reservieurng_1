# Supabase Postgres Connection (Project Settings > Database > Connection String)
DATABASE_URL=postgresql://postgres.xxxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Server
PORT=3001
NODE_ENV=development

# Public Base URL (used in confirmation/cancellation emails)
BASE_URL=http://localhost:5173

# Restaurant Info (Fallbacks – kann zur Laufzeit im Admin-Dashboard überschrieben werden)
RESTAURANT_NAME=Ristorante Bella Vista
RESTAURANT_ADDRESS=Hauptstraße 1, 12345 Stadt
RESTAURANT_PHONE=+49 30 12345678
RESTAURANT_MAPS_URL=https://maps.google.com

# Admin Login
ADMIN_PASSWORD=ChangeMe123!

# SMTP (optional in DEV – Emails werden ohne SMTP nur in der Konsole geloggt)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Ristorante Bella Vista <reservierung@bellavista.de>
