# Supabase Postgres Connection (Project Settings > Database > Connection String)
DATABASE_URL=postgresql://postgres.xxxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Server
PORT=3001
NODE_ENV=development

# Zeitzone des Restaurants. WICHTIG: ohne diese Variable laufen Server (z.B. Render)
# in UTC und alle Uhrzeiten sind verschoben. Gleicher Wert wie in render.yaml.
TZ=Europe/Berlin

# Public Base URL (used in confirmation/cancellation emails)
# Lokal: http://localhost:5173 – Production: https://<service>.onrender.com
BASE_URL=http://localhost:5173

# Restaurant Info (Fallbacks – kann zur Laufzeit im Admin-Dashboard überschrieben werden)
RESTAURANT_NAME=Ristorante Bella Vista
RESTAURANT_ADDRESS=Hauptstraße 1, 12345 Stadt
RESTAURANT_PHONE=+49 30 12345678
RESTAURANT_MAPS_URL=https://maps.google.com

# Admin Login (min. 8 Zeichen, in Production verboten: admin123/changeme/password)
ADMIN_PASSWORD=BitteSicheresPasswortSetzen2026

# Secret für den externen Cron-Trigger /api/cron/run (zufälliger langer String).
# Ein externer Scheduler (cron-job.org) ruft alle 15 Min auf:
#   https://<service>.onrender.com/api/cron/run?key=<CRON_SECRET>
# Das weckt Render aus dem Sleep UND verschickt fällige Erinnerungen.
CRON_SECRET=bitte-langen-zufallswert-setzen

# Legal (für Impressum & Datenschutz – DSGVO Pflicht in DE)
LEGAL_OWNER_NAME=Max Mustermann
LEGAL_OWNER_EMAIL=info@bella-vista.example
# LEGAL_TAX_ID=DE123456789  # optional, bei Kleinunternehmer leer lassen

# ─────────────────────────────────────────────────────────────────────────
# E-Mail-Versand
# Empfohlen für Render/Cloud: Brevo HTTP-API (Port 443, wird nie blockiert).
# Setze BREVO_API_KEY → dann wird Brevo statt SMTP genutzt (SMTP_* ignoriert).
# Brevo: kostenlos 300 Mails/Tag, Absender-Mail im Brevo-Dashboard verifizieren
# (keine eigene Domain nötig). Key: app.brevo.com → SMTP & API → API Keys.
# BREVO_API_KEY=xkeysib-...
# Optional eigener Absender, sonst wird SMTP_FROM genutzt:
# BREVO_FROM="Ristorante Bella Vista <deine.adresse@gmail.com>"
# ─────────────────────────────────────────────────────────────────────────

# SMTP (nur lokal/Server ohne SMTP-Block – Gmail beste Deliverability ohne Domain)
# SMTP_PASS = 16-stelliges Gmail App-Passwort (NICHT das normale Passwort!)
# Generieren: https://myaccount.google.com/apppasswords (2FA muss aktiv sein)
# SMTP_FROM-Adresse MUSS = SMTP_USER sein, sonst Spam-Score höher.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.address@gmail.com
SMTP_PASS=dein16stelligesapppasswort
SMTP_FROM="Ristorante Bella Vista <your.address@gmail.com>"
REPLY_TO=your.address@gmail.com
